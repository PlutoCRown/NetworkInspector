[
  {
    "capture": [
      "data\\.a1\\.art"
    ],
    "enabled": true,
    "id": "acme-analytics-2026",
    "name": "A1.art 埋点捕获",
    "rules": [
      {
        "fields": {
          "desc": "[aggregate:item]distinct_id",
          "expand": "[aggregate:item]properties",
          "title": "[aggregate:item]action"
        },
        "id": "rule-a1",
        "renderer": "card",
        "splits": {
          "item": "[source:json]"
        },
        "url": "data\\.a1\\.art"
      }
    ],
    "sites": [
      "a1.art/.*"
    ],
    "version": 1
  },
  {
    "capture": [
      "mcs.zijieapi.com/list"
    ],
    "enabled": true,
    "id": "group-1778944597173",
    "name": "抖音测试用",
    "rules": [
      {
        "fields": {
          "desc": "[aggregate:item]session_id",
          "expand": "[aggregate:item]params[processor:JSONParser]",
          "title": "[aggregate:item]event"
        },
        "id": "rule-1778944597173",
        "renderer": "card",
        "splits": {
          "item": "[source:json]0.events"
        },
        "url": "mcs.zijieapi.com/list"
      }
    ],
    "sites": [
      "douyin.com/.*"
    ],
    "version": 1
  }
