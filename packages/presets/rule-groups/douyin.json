{
  "version": 1,
  "id": "group-douyin",
  "name": "DOUYIN",
  "enabled": true,
  "sites": [
    "douyin.com/.*"
  ],
  "capture": [
    "mcs.zijieapi.com/list"
  ],
  "rules": [
    {
      "id": "rule-douyin-list",
      "url": "mcs.zijieapi.com/list",
      "renderer": "card",
      "splits": {
        "item": "[source:json]0.events"
      },
      "fields": {
        "title": "[aggregate:item]event",
        "popover": "[aggregate:item]params"
      }
    }
  ]
}